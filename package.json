{
  "name": "kit-claude-proxy",
  "version": "1.0.0",
  "description": "OpenAI-compatible proxy for Claude Code CLI — with content block support, tool calls, and improved error handling",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "kit-claude-proxy": "dist/server/standalone.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/server/standalone.js",
    "test": "node --test dist/**/*.test.js",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "claude",
    "anthropic",
    "claude-code",
    "claude-max",
    "openai-compatible",
    "api-server",
    "oauth",
    "llm",
    "ai",
    "proxy"
  ],
  "author": "Kit",
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "express": "^4.18.2",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.0",
    "@types/uuid": "^9.0.7",
    "typescript": "^5.3.3"
  }
}
